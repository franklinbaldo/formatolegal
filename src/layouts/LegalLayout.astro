---
import '@picocss/pico/css/pico.conditional.min.css';
import 'katex/dist/katex.min.css';
import 'highlight.js/styles/github.css';
const { title } = Astro.props;
---

<html lang="pt-br">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{title || 'Petição de Apelação'}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400..700;1,400..700&family=Montserrat:wght@400;700&family=Caveat:wght@400;700&family=Cinzel:wght@400;700&family=EB+Garamond:ital,wght@0,400..700;1,400..700&family=Inter:wght@400;700&family=JetBrains+Mono:wght@400;700&family=Nunito:wght@400;700&family=Quicksand:wght@400;700&family=Space+Grotesk:wght@400;700&display=swap"
			rel="stylesheet"
		/>
		<style is:global>
			:root {
				--paper-width: 210mm;
				--paper-height: 297mm;
				--margin-top: 30mm;
				--margin-bottom: 25mm;
				--margin-left: 30mm;
				--margin-right: 20mm;
				--primary-color: #1a2a44;
				--paper-bg: white;
				--paper-color: #333;
			}

			body {
				background-color: #f0f2f5;
				margin: 0;
				padding: 40px 0;
				font-family: 'Lora', serif;
				color: #333;
				line-height: 1.6;
			}

			.page-container {
				width: var(--paper-width);
				min-height: var(--paper-height);
				background: var(--paper-bg);
				color: var(--paper-color);
				margin: 0 auto;
				padding: var(--margin-top) var(--margin-right) var(--margin-bottom) var(--margin-left);
				box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
				box-sizing: border-box;
				position: relative;
			}

			article {
				text-align: justify;
				hyphens: auto;
			}

			h1,
			h2,
			h3,
			h4 {
				font-family: 'Montserrat', sans-serif;
				color: var(--primary-color);
				margin-top: 2em;
				margin-bottom: 1em;
			}

			h2 {
				border-left: 4px solid var(--primary-color);
				padding-left: 15px;
				font-size: 1.5rem;
				text-transform: uppercase;
			}

			h3 {
				font-size: 1.2rem;
				font-weight: 700;
				color: #444;
			}

			p {
				margin-bottom: 1.5em;
				text-indent: 2em;
			}

			strong {
				font-weight: 700;
			}

			blockquote {
				margin: 1.5em 3em;
				font-size: 0.95em;
				color: #555;
				border-left: 2px solid #ddd;
				padding-left: 1.5em;
				text-align: justify;
			}

			ul,
			ol {
				margin-bottom: 1.5em;
				padding-left: 3em;
			}

			li {
				margin-bottom: 0.5em;
			}

			.footer-signature {
				margin-top: 60px;
				text-align: center;
			}

			hr {
				border: none;
				border-top: 1px dashed #ccc;
				margin: 60px 0;
				page-break-before: always;
				position: relative;
				height: 0;
				overflow: visible;
			}

			hr::after {
				content: 'QUEBRA DE PÁGINA';
				position: absolute;
				top: -10px;
				right: 0;
				font-family: 'Montserrat', sans-serif;
				font-size: 10px;
				color: #999;
				background: white;
				padding: 0 10px;
			}

			/* === Tema Clássico === */
			.theme-classic {
				font-family: 'Times New Roman', Times, serif;
			}
			.theme-classic h1,
			.theme-classic h2,
			.theme-classic h3 {
				font-family: 'Times New Roman', Times, serif;
				text-transform: uppercase;
				border-bottom: 1px solid #333;
			}

			/* === Tema ABNT (Times 12, 1,5; margens 3/2/2/3) === */
			.theme-abnt {
				--margin-top: 30mm;
				--margin-right: 20mm;
				--margin-bottom: 20mm;
				--margin-left: 30mm;
				font-family: 'Times New Roman', Times, serif;
				font-size: 12pt;
				line-height: 1.5;
			}
			.theme-abnt h1,
			.theme-abnt h2,
			.theme-abnt h3,
			.theme-abnt h4 {
				font-family: 'Times New Roman', Times, serif;
				color: #000;
				text-transform: none;
				border: none;
				padding: 0;
				font-weight: 700;
			}
			.theme-abnt h1 {
				font-size: 12pt;
				text-transform: uppercase;
				text-align: center;
			}
			.theme-abnt h2 {
				font-size: 12pt;
				text-transform: uppercase;
			}
			.theme-abnt h3 {
				font-size: 12pt;
			}
			.theme-abnt p {
				text-indent: 1.25cm;
				margin-bottom: 0;
				text-align: justify;
			}

			/* === Tema CNJ / STF-STJ (Arial 12, 1,5; margens 3/2/2/3) === */
			.theme-cnj {
				--margin-top: 30mm;
				--margin-right: 20mm;
				--margin-bottom: 20mm;
				--margin-left: 30mm;
				font-family: Arial, Helvetica, sans-serif;
				font-size: 12pt;
				line-height: 1.5;
			}
			.theme-cnj h1,
			.theme-cnj h2,
			.theme-cnj h3,
			.theme-cnj h4 {
				font-family: Arial, Helvetica, sans-serif;
				color: #000;
				text-transform: none;
				border: none;
				padding: 0;
				font-weight: 700;
			}
			.theme-cnj h1 {
				font-size: 12pt;
				text-align: center;
				text-transform: uppercase;
			}
			.theme-cnj h2 {
				font-size: 12pt;
				text-transform: uppercase;
			}
			.theme-cnj h3 {
				font-size: 12pt;
			}
			.theme-cnj p {
				text-indent: 1.25cm;
				margin-bottom: 0;
				text-align: justify;
			}

			/* === Tema OAB Tradicional (Times 12, 1,5; H2 numerado em romanos) === */
			.theme-oab {
				--margin-top: 30mm;
				--margin-right: 20mm;
				--margin-bottom: 30mm;
				--margin-left: 30mm;
				font-family: 'Times New Roman', Times, serif;
				font-size: 12pt;
				line-height: 1.5;
				counter-reset: oab-section;
			}
			.theme-oab h1,
			.theme-oab h2,
			.theme-oab h3 {
				font-family: 'Times New Roman', Times, serif;
				color: #000;
				border: none;
				padding: 0;
				font-weight: 700;
			}
			.theme-oab h1 {
				font-size: 12pt;
				text-align: center;
				text-transform: uppercase;
			}
			.theme-oab h2 {
				font-size: 12pt;
				text-transform: uppercase;
				counter-increment: oab-section;
			}
			.theme-oab h2::before {
				content: counter(oab-section, upper-roman) '. ';
			}
			.theme-oab h3 {
				font-size: 12pt;
			}
			.theme-oab p {
				text-indent: 2cm;
				margin-bottom: 0;
				text-align: justify;
			}

			/* === Tema Contrato (Times 11, single, cláusulas hierárquicas) === */
			.theme-contrato {
				--margin-top: 25mm;
				--margin-right: 20mm;
				--margin-bottom: 25mm;
				--margin-left: 25mm;
				font-family: 'Times New Roman', Times, serif;
				font-size: 11pt;
				line-height: 1.25;
			}
			.theme-contrato h1,
			.theme-contrato h2,
			.theme-contrato h3 {
				font-family: 'Times New Roman', Times, serif;
				color: #000;
				border: none;
				padding: 0;
				font-weight: 700;
				text-transform: uppercase;
				font-size: 11pt;
			}
			.theme-contrato h1 {
				text-align: center;
				margin-bottom: 1.5em;
			}
			.theme-contrato p {
				text-indent: 0;
				margin-bottom: 0.75em;
				text-align: justify;
			}
			.theme-contrato ol {
				counter-reset: clause;
				list-style: none;
				padding-left: 0;
			}
			.theme-contrato ol > li {
				counter-increment: clause;
				margin-bottom: 0.5em;
				text-align: justify;
			}
			.theme-contrato ol > li::before {
				content: counters(clause, '.') '. ';
				font-weight: 700;
				margin-right: 0.25em;
			}

			/* ============================================================
			   TEMAS DIVERTIDOS — designs alternativos com personalidade.
			   Não seguem normas oficiais; uso para rascunhos, memorandos
			   internos, trabalhos acadêmicos ou só por prazer.
			   ============================================================ */

			/* === Cyberpunk Noturno === */
			.theme-cyberpunk {
				--margin-top: 25mm;
				--margin-right: 20mm;
				--margin-bottom: 25mm;
				--margin-left: 20mm;
				--paper-bg: #0d0d12;
				--paper-color: #e6e6f0;
				color: var(--paper-color);
				font-family: 'Inter', system-ui, sans-serif;
				font-size: 11pt;
				line-height: 1.65;
			}
			.theme-cyberpunk h1,
			.theme-cyberpunk h2,
			.theme-cyberpunk h3,
			.theme-cyberpunk h4 {
				font-family: 'JetBrains Mono', ui-monospace, monospace;
				color: #ff2b9d;
				text-transform: uppercase;
				letter-spacing: 0.05em;
				border: none;
				padding: 0;
				text-shadow:
					0 0 8px rgba(255, 43, 157, 0.6),
					0 0 16px rgba(255, 43, 157, 0.3);
			}
			.theme-cyberpunk h1 {
				font-size: 1.8rem;
				border-bottom: 2px solid #ff2b9d;
				padding-bottom: 0.3em;
			}
			.theme-cyberpunk h2 {
				color: #00f0ff;
				text-shadow:
					0 0 8px rgba(0, 240, 255, 0.6),
					0 0 16px rgba(0, 240, 255, 0.3);
			}
			.theme-cyberpunk h2::before {
				content: '> ';
				color: #ff2b9d;
				text-shadow: 0 0 6px rgba(255, 43, 157, 0.7);
			}
			.theme-cyberpunk h3 {
				color: #c5a8ff;
				text-shadow: 0 0 6px rgba(197, 168, 255, 0.5);
			}
			.theme-cyberpunk strong {
				color: #ffd166;
			}
			.theme-cyberpunk a {
				color: #00f0ff;
				text-shadow: 0 0 6px rgba(0, 240, 255, 0.5);
			}
			.theme-cyberpunk blockquote {
				border-left: 3px solid #00f0ff;
				background: rgba(0, 240, 255, 0.08);
				color: #b9d9ff;
				font-style: italic;
				box-shadow: inset 0 0 20px rgba(0, 240, 255, 0.1);
			}
			.theme-cyberpunk code {
				background: rgba(255, 43, 157, 0.15);
				color: #ffd166;
			}
			.theme-cyberpunk hr {
				border-top: 1px solid #ff2b9d;
				box-shadow: 0 0 10px rgba(255, 43, 157, 0.6);
			}
			.theme-cyberpunk hr::after {
				background: #0d0d12;
				color: #00f0ff;
			}

			/* === Manuscrito Vintage === */
			.theme-vintage {
				--margin-top: 35mm;
				--margin-right: 25mm;
				--margin-bottom: 30mm;
				--margin-left: 25mm;
				--paper-bg:
					radial-gradient(ellipse at top left, rgba(180, 140, 80, 0.08), transparent 60%),
					radial-gradient(ellipse at bottom right, rgba(140, 100, 50, 0.06), transparent 60%),
					#f4ecd8;
				--paper-color: #3a2a14;
				color: var(--paper-color);
				font-family: 'EB Garamond', 'Garamond', serif;
				font-size: 13pt;
				line-height: 1.7;
			}
			.theme-vintage h1,
			.theme-vintage h2,
			.theme-vintage h3 {
				font-family: 'Cinzel', serif;
				color: #5a3a1a;
				text-align: center;
				border: none;
				padding: 0;
				letter-spacing: 0.1em;
			}
			.theme-vintage h1 {
				font-size: 1.6rem;
				font-variant: small-caps;
				margin-bottom: 0.2em;
			}
			.theme-vintage h1::after {
				content: '✦  ✦  ✦';
				display: block;
				font-size: 0.7em;
				color: #8a6a3a;
				letter-spacing: 0.5em;
				margin-top: 0.2em;
			}
			.theme-vintage h2 {
				font-variant: small-caps;
				font-size: 1.2rem;
				border-bottom: 1px solid #b89a6a;
				padding-bottom: 0.2em;
			}
			.theme-vintage article > p:first-of-type::first-letter {
				font-family: 'Cinzel', serif;
				font-size: 3.5em;
				float: left;
				line-height: 0.85;
				margin: 0.05em 0.1em 0 0;
				color: #6a3a1a;
				font-weight: 700;
			}
			.theme-vintage blockquote {
				border-left: 3px double #8a6a3a;
				font-style: italic;
				color: #5a4a2a;
			}
			.theme-vintage hr {
				border: none;
				text-align: center;
				margin: 2em 0;
				page-break-before: auto;
				height: auto;
			}
			.theme-vintage hr::after {
				content: '✦  ✧  ✦';
				position: static;
				background: transparent;
				color: #8a6a3a;
				font-size: 1.2em;
				letter-spacing: 0.5em;
				padding: 0;
			}

			/* === Pastel Sereno === */
			.theme-pastel {
				--margin-top: 28mm;
				--margin-right: 22mm;
				--margin-bottom: 28mm;
				--margin-left: 22mm;
				--paper-bg: linear-gradient(135deg, #fef4f0 0%, #f5edf8 50%, #eaf6f1 100%);
				--paper-color: #3d3654;
				color: var(--paper-color);
				font-family: 'Nunito', system-ui, sans-serif;
				font-size: 11.5pt;
				line-height: 1.7;
			}
			.theme-pastel h1,
			.theme-pastel h2,
			.theme-pastel h3 {
				font-family: 'Quicksand', sans-serif;
				color: #6e4f8a;
				border: none;
				padding: 0;
				font-weight: 700;
			}
			.theme-pastel h1 {
				font-size: 1.8rem;
				text-align: center;
				background: linear-gradient(90deg, #f8b4c8, #c8a4e8, #a4d8c8);
				-webkit-background-clip: text;
				background-clip: text;
				color: transparent;
				margin-bottom: 1em;
			}
			.theme-pastel h2 {
				display: inline-block;
				background: linear-gradient(135deg, #fce4ec, #e8d6f4);
				color: #5a3d7a;
				padding: 0.4em 1em;
				border-radius: 999px;
				font-size: 1.1rem;
				box-shadow: 0 2px 8px rgba(110, 79, 138, 0.15);
				text-transform: none;
			}
			.theme-pastel h3 {
				color: #8a6ba8;
				font-size: 1.05rem;
			}
			.theme-pastel strong {
				color: #d6789a;
			}
			.theme-pastel blockquote {
				background: rgba(255, 255, 255, 0.6);
				border-left: 4px solid #c8a4e8;
				border-radius: 0 12px 12px 0;
				color: #5a4d6a;
				padding: 1em 1.5em;
				box-shadow: 0 2px 12px rgba(110, 79, 138, 0.08);
			}
			.theme-pastel hr {
				border: none;
				background: linear-gradient(90deg, transparent, #c8a4e8, transparent);
				height: 2px;
				border-radius: 2px;
				margin: 2.5em 0;
			}
			.theme-pastel hr::after {
				display: none;
			}

			/* === Brutalista === */
			.theme-brutalist {
				--margin-top: 30mm;
				--margin-right: 25mm;
				--margin-bottom: 30mm;
				--margin-left: 25mm;
				--paper-bg: #fff;
				--paper-color: #000;
				color: var(--paper-color);
				font-family: 'Space Grotesk', system-ui, sans-serif;
				font-size: 12pt;
				line-height: 1.5;
				border: 4px solid #000;
				box-shadow: 12px 12px 0 #000 !important;
			}
			.theme-brutalist h1,
			.theme-brutalist h2,
			.theme-brutalist h3,
			.theme-brutalist h4 {
				font-family: 'Space Grotesk', sans-serif;
				color: #000;
				font-weight: 700;
				text-transform: uppercase;
				letter-spacing: -0.02em;
				border: none;
				padding: 0;
			}
			.theme-brutalist h1 {
				font-size: 3rem;
				line-height: 0.95;
				background: #000;
				color: #fff;
				padding: 0.4em 0.5em;
				margin: 0 -0.2em 1em -0.2em;
				display: block;
			}
			.theme-brutalist h2 {
				font-size: 1.6rem;
				border-bottom: 4px solid #000;
				padding-bottom: 0.1em;
				margin-top: 2em;
			}
			.theme-brutalist h2::after {
				content: ' ▮';
				color: #d92d2d;
			}
			.theme-brutalist h3 {
				font-size: 1.2rem;
				text-decoration: underline;
				text-decoration-thickness: 3px;
				text-underline-offset: 4px;
			}
			.theme-brutalist strong {
				background: #000;
				color: #fff;
				padding: 0 0.2em;
			}
			.theme-brutalist blockquote {
				border-left: 8px solid #d92d2d;
				background: #fff;
				color: #000;
				font-weight: 500;
				padding: 1em 1.5em;
				margin: 1.5em 0;
			}
			.theme-brutalist a {
				color: #d92d2d;
				font-weight: 700;
				text-decoration: underline;
				text-decoration-thickness: 2px;
			}
			.theme-brutalist hr {
				border-top: 4px solid #000;
				margin: 2em 0;
			}
			.theme-brutalist hr::after {
				background: #fff;
				color: #000;
				font-weight: 700;
				border: 2px solid #000;
			}

			/* === Petição Festa (full fun + emoji) === */
			.theme-festa {
				--margin-top: 25mm;
				--margin-right: 20mm;
				--margin-bottom: 25mm;
				--margin-left: 20mm;
				--paper-bg: linear-gradient(135deg, #fff5f7 0%, #fef9e7 50%, #e7f9ff 100%);
				--paper-color: #2a2a3e;
				color: var(--paper-color);
				font-family: 'Nunito', system-ui, sans-serif;
				font-size: 12pt;
				line-height: 1.7;
				position: relative;
			}
			.theme-festa::before {
				content: '';
				position: absolute;
				top: 0;
				left: 0;
				right: 0;
				height: 12px;
				background:
					linear-gradient(
						90deg,
						#ff6b9d 0%,
						#ffd166 20%,
						#06d6a0 40%,
						#118ab2 60%,
						#c77dff 80%,
						#ff6b9d 100%
					);
			}
			.theme-festa h1,
			.theme-festa h2,
			.theme-festa h3 {
				font-family: 'Caveat', cursive;
				border: none;
				padding: 0;
				font-weight: 700;
			}
			.theme-festa h1 {
				font-size: 3rem;
				text-align: center;
				color: #ff6b9d;
				line-height: 1.1;
				margin: 0.5em 0;
			}
			.theme-festa h1::before {
				content: '⚖️ ';
			}
			.theme-festa h1::after {
				content: ' ✨';
			}
			.theme-festa h2 {
				font-size: 2rem;
				color: #118ab2;
				background: rgba(255, 209, 102, 0.3);
				padding: 0.1em 0.4em;
				border-radius: 12px;
				display: inline-block;
				transform: rotate(-1deg);
				text-transform: none;
			}
			.theme-festa h2::before {
				content: '📜 ';
			}
			.theme-festa h3 {
				font-size: 1.5rem;
				color: #c77dff;
			}
			.theme-festa h3::before {
				content: '✨ ';
			}
			.theme-festa strong {
				background: linear-gradient(120deg, #ffd166aa 0%, #ffd16633 100%);
				padding: 0 0.15em;
				border-radius: 4px;
			}
			.theme-festa em {
				color: #ef476f;
			}
			.theme-festa blockquote {
				background: linear-gradient(135deg, #fff5f7, #fef9e7);
				border: 2px dashed #ff6b9d;
				border-radius: 16px;
				padding: 1em 1.5em;
				color: #5a3a4a;
				margin: 1.5em 0.5em;
				position: relative;
			}
			.theme-festa blockquote::before {
				content: '✍️';
				position: absolute;
				top: -14px;
				left: 12px;
				background: white;
				padding: 0 8px;
				font-size: 1.4em;
			}
			.theme-festa ul {
				list-style: none;
				padding-left: 1.5em;
			}
			.theme-festa ul > li {
				position: relative;
			}
			.theme-festa ul > li::before {
				content: '🎀';
				position: absolute;
				left: -1.5em;
			}
			.theme-festa ol {
				list-style: none;
				counter-reset: festa;
				padding-left: 2em;
			}
			.theme-festa ol > li {
				counter-increment: festa;
				position: relative;
			}
			.theme-festa ol > li::before {
				content: counter(festa) '.';
				position: absolute;
				left: -2em;
				color: #06d6a0;
				font-weight: 700;
				font-family: 'Caveat', cursive;
				font-size: 1.3em;
			}
			.theme-festa hr {
				border: none;
				text-align: center;
				margin: 2.5em 0;
				height: auto;
				page-break-before: auto;
			}
			.theme-festa hr::after {
				content: '🎉 ✦ 🎊';
				position: static;
				background: transparent;
				color: inherit;
				font-size: 1.3em;
				letter-spacing: 0.5em;
				padding: 0;
			}
			.theme-festa a {
				color: #118ab2;
				text-decoration-color: #ffd166;
				text-decoration-thickness: 2px;
			}

			/* === Mermaid === */
			.mermaid-diagram {
				margin: 1.5em auto;
				text-align: center;
				max-width: 100%;
				page-break-inside: avoid;
			}
			.mermaid-diagram svg {
				max-width: 100%;
				height: auto;
			}
			.mermaid-error {
				background: #fff5f5;
				border-left: 4px solid #c92a2a;
				padding: 0.75em 1em;
				color: #842029;
				font-family: 'Fira Code', monospace;
				font-size: 0.9em;
				white-space: pre-wrap;
			}

			/* === GitHub-style alerts (marked-alert) === */
			.markdown-alert {
				margin: 1em 0;
				padding: 0.75em 1em;
				border-left: 4px solid var(--alert-color, #888);
				background: var(--alert-bg, #f6f8fa);
				border-radius: 0 4px 4px 0;
				text-indent: 0;
			}
			.markdown-alert > p {
				text-indent: 0;
				margin-bottom: 0.5em;
			}
			.markdown-alert > p:last-child {
				margin-bottom: 0;
			}
			.markdown-alert-title {
				font-weight: 700;
				text-transform: uppercase;
				font-size: 0.85em;
				letter-spacing: 0.05em;
				display: flex;
				align-items: center;
				gap: 0.4em;
			}
			.markdown-alert-note {
				--alert-color: #0969da;
				--alert-bg: #ddf4ff;
			}
			.markdown-alert-tip {
				--alert-color: #1a7f37;
				--alert-bg: #dcfce7;
			}
			.markdown-alert-important {
				--alert-color: #8250df;
				--alert-bg: #f3e8ff;
			}
			.markdown-alert-warning {
				--alert-color: #bf8700;
				--alert-bg: #fff8c5;
			}
			.markdown-alert-caution {
				--alert-color: #cf222e;
				--alert-bg: #ffebe9;
			}

			/* === Footnotes (marked-footnote) === */
			.footnotes {
				margin-top: 3em;
				padding-top: 1em;
				border-top: 1px solid #ccc;
				font-size: 0.9em;
			}
			.footnotes ol {
				padding-left: 2em;
			}
			.footnotes li {
				text-indent: 0;
			}
			[data-footnote-ref] {
				font-size: 0.75em;
				vertical-align: super;
				text-decoration: none;
			}
			[data-footnote-backref] {
				text-decoration: none;
				margin-left: 0.3em;
			}

			/* === Code blocks (highlight.js) === */
			pre code.hljs {
				display: block;
				overflow-x: auto;
				padding: 0.75em 1em;
				border-radius: 4px;
				font-size: 0.875em;
				line-height: 1.5;
			}
			:not(pre) > code {
				background: rgba(175, 184, 193, 0.2);
				padding: 0.15em 0.35em;
				border-radius: 3px;
				font-size: 0.875em;
				font-family: 'Fira Code', 'Cascadia Code', monospace;
			}

			/* === Task lists (GFM) === */
			.task-list-item {
				list-style: none;
				text-indent: 0;
			}
			.task-list-item input[type='checkbox'] {
				margin-right: 0.5em;
				transform: translateY(1px);
			}
			ul:has(> .task-list-item) {
				padding-left: 1.5em;
			}

			/* === KaTeX adjustments === */
			.katex-display {
				margin: 1em 0;
				overflow-x: auto;
				overflow-y: hidden;
			}

			/* === Numeração de parágrafos (toggle independente) === */
			.numbered-paragraphs article {
				counter-reset: para;
			}
			.numbered-paragraphs article > p {
				counter-increment: para;
				position: relative;
				padding-left: 2.5em;
				text-indent: 0;
			}
			.numbered-paragraphs article > p::before {
				content: counter(para) '.';
				position: absolute;
				left: 0;
				font-weight: 700;
				width: 2em;
				text-align: right;
			}

			@page {
				size: A4;
				margin: 25mm 20mm;
				@bottom-right {
					content: 'Pág. ' counter(page) ' de ' counter(pages);
					font-family: inherit;
					font-size: 9pt;
					color: #555;
				}
			}

			@media print {
				body {
					background: white !important;
					padding: 0 !important;
				}
				.page-container {
					box-shadow: none !important;
					margin: 0 !important;
					width: 100% !important;
				}
				hr {
					border: none;
					margin: 0;
				}
				hr::after {
					display: none;
				}
			}
		</style>
	</head>
	<body>
		<slot />
	</body>
</html>
