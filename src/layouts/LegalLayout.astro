---
import '@picocss/pico/css/pico.conditional.min.css';
const { title } = Astro.props;
---

<html lang="pt-br">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{title || 'Petição de Apelação'}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400..700;1,400..700&family=Montserrat:wght@400;700&display=swap"
			rel="stylesheet"
		/>
		<style is:global>
			:root {
				--paper-width: 210mm;
				--paper-height: 297mm;
				--margin-top: 30mm;
				--margin-bottom: 25mm;
				--margin-left: 30mm;
				--margin-right: 20mm;
				--primary-color: #1a2a44;
			}

			body {
				background-color: #f0f2f5;
				margin: 0;
				padding: 40px 0;
				font-family: 'Lora', serif;
				color: #333;
				line-height: 1.6;
			}

			.page-container {
				width: var(--paper-width);
				min-height: var(--paper-height);
				background: white;
				margin: 0 auto;
				padding: var(--margin-top) var(--margin-right) var(--margin-bottom) var(--margin-left);
				box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
				box-sizing: border-box;
				position: relative;
			}

			article {
				text-align: justify;
				hyphens: auto;
			}

			h1,
			h2,
			h3,
			h4 {
				font-family: 'Montserrat', sans-serif;
				color: var(--primary-color);
				margin-top: 2em;
				margin-bottom: 1em;
			}

			h2 {
				border-left: 4px solid var(--primary-color);
				padding-left: 15px;
				font-size: 1.5rem;
				text-transform: uppercase;
			}

			h3 {
				font-size: 1.2rem;
				font-weight: 700;
				color: #444;
			}

			p {
				margin-bottom: 1.5em;
				text-indent: 2em;
			}

			strong {
				font-weight: 700;
			}

			blockquote {
				margin: 1.5em 3em;
				font-size: 0.95em;
				color: #555;
				border-left: 2px solid #ddd;
				padding-left: 1.5em;
				text-align: justify;
			}

			ul,
			ol {
				margin-bottom: 1.5em;
				padding-left: 3em;
			}

			li {
				margin-bottom: 0.5em;
			}

			.footer-signature {
				margin-top: 60px;
				text-align: center;
			}

			hr {
				border: none;
				border-top: 1px dashed #ccc;
				margin: 60px 0;
				page-break-before: always;
				position: relative;
				height: 0;
				overflow: visible;
			}

			hr::after {
				content: 'QUEBRA DE PÁGINA';
				position: absolute;
				top: -10px;
				right: 0;
				font-family: 'Montserrat', sans-serif;
				font-size: 10px;
				color: #999;
				background: white;
				padding: 0 10px;
			}

			/* === Tema Clássico === */
			.theme-classic {
				font-family: 'Times New Roman', Times, serif;
			}
			.theme-classic h1,
			.theme-classic h2,
			.theme-classic h3 {
				font-family: 'Times New Roman', Times, serif;
				text-transform: uppercase;
				border-bottom: 1px solid #333;
			}

			/* === Tema ABNT (Times 12, 1,5; margens 3/2/2/3) === */
			.theme-abnt {
				--margin-top: 30mm;
				--margin-right: 20mm;
				--margin-bottom: 20mm;
				--margin-left: 30mm;
				font-family: 'Times New Roman', Times, serif;
				font-size: 12pt;
				line-height: 1.5;
			}
			.theme-abnt h1,
			.theme-abnt h2,
			.theme-abnt h3,
			.theme-abnt h4 {
				font-family: 'Times New Roman', Times, serif;
				color: #000;
				text-transform: none;
				border: none;
				padding: 0;
				font-weight: 700;
			}
			.theme-abnt h1 {
				font-size: 12pt;
				text-transform: uppercase;
				text-align: center;
			}
			.theme-abnt h2 {
				font-size: 12pt;
				text-transform: uppercase;
			}
			.theme-abnt h3 {
				font-size: 12pt;
			}
			.theme-abnt p {
				text-indent: 1.25cm;
				margin-bottom: 0;
				text-align: justify;
			}

			/* === Tema CNJ / STF-STJ (Arial 12, 1,5; margens 3/2/2/3) === */
			.theme-cnj {
				--margin-top: 30mm;
				--margin-right: 20mm;
				--margin-bottom: 20mm;
				--margin-left: 30mm;
				font-family: Arial, Helvetica, sans-serif;
				font-size: 12pt;
				line-height: 1.5;
			}
			.theme-cnj h1,
			.theme-cnj h2,
			.theme-cnj h3,
			.theme-cnj h4 {
				font-family: Arial, Helvetica, sans-serif;
				color: #000;
				text-transform: none;
				border: none;
				padding: 0;
				font-weight: 700;
			}
			.theme-cnj h1 {
				font-size: 12pt;
				text-align: center;
				text-transform: uppercase;
			}
			.theme-cnj h2 {
				font-size: 12pt;
				text-transform: uppercase;
			}
			.theme-cnj h3 {
				font-size: 12pt;
			}
			.theme-cnj p {
				text-indent: 1.25cm;
				margin-bottom: 0;
				text-align: justify;
			}

			/* === Tema OAB Tradicional (Times 12, 1,5; H2 numerado em romanos) === */
			.theme-oab {
				--margin-top: 30mm;
				--margin-right: 20mm;
				--margin-bottom: 30mm;
				--margin-left: 30mm;
				font-family: 'Times New Roman', Times, serif;
				font-size: 12pt;
				line-height: 1.5;
				counter-reset: oab-section;
			}
			.theme-oab h1,
			.theme-oab h2,
			.theme-oab h3 {
				font-family: 'Times New Roman', Times, serif;
				color: #000;
				border: none;
				padding: 0;
				font-weight: 700;
			}
			.theme-oab h1 {
				font-size: 12pt;
				text-align: center;
				text-transform: uppercase;
			}
			.theme-oab h2 {
				font-size: 12pt;
				text-transform: uppercase;
				counter-increment: oab-section;
			}
			.theme-oab h2::before {
				content: counter(oab-section, upper-roman) '. ';
			}
			.theme-oab h3 {
				font-size: 12pt;
			}
			.theme-oab p {
				text-indent: 2cm;
				margin-bottom: 0;
				text-align: justify;
			}

			/* === Tema Contrato (Times 11, single, cláusulas hierárquicas) === */
			.theme-contrato {
				--margin-top: 25mm;
				--margin-right: 20mm;
				--margin-bottom: 25mm;
				--margin-left: 25mm;
				font-family: 'Times New Roman', Times, serif;
				font-size: 11pt;
				line-height: 1.25;
			}
			.theme-contrato h1,
			.theme-contrato h2,
			.theme-contrato h3 {
				font-family: 'Times New Roman', Times, serif;
				color: #000;
				border: none;
				padding: 0;
				font-weight: 700;
				text-transform: uppercase;
				font-size: 11pt;
			}
			.theme-contrato h1 {
				text-align: center;
				margin-bottom: 1.5em;
			}
			.theme-contrato p {
				text-indent: 0;
				margin-bottom: 0.75em;
				text-align: justify;
			}
			.theme-contrato ol {
				counter-reset: clause;
				list-style: none;
				padding-left: 0;
			}
			.theme-contrato ol > li {
				counter-increment: clause;
				margin-bottom: 0.5em;
				text-align: justify;
			}
			.theme-contrato ol > li::before {
				content: counters(clause, '.') '. ';
				font-weight: 700;
				margin-right: 0.25em;
			}

			/* === Numeração de parágrafos (toggle independente) === */
			.numbered-paragraphs article {
				counter-reset: para;
			}
			.numbered-paragraphs article > p {
				counter-increment: para;
				position: relative;
				padding-left: 2.5em;
				text-indent: 0;
			}
			.numbered-paragraphs article > p::before {
				content: counter(para) '.';
				position: absolute;
				left: 0;
				font-weight: 700;
				width: 2em;
				text-align: right;
			}

			@page {
				size: A4;
				margin: 25mm 20mm;
				@bottom-right {
					content: 'Pág. ' counter(page) ' de ' counter(pages);
					font-family: inherit;
					font-size: 9pt;
					color: #555;
				}
			}

			@media print {
				body {
					background: white !important;
					padding: 0 !important;
				}
				.page-container {
					box-shadow: none !important;
					margin: 0 !important;
					width: 100% !important;
				}
				hr {
					border: none;
					margin: 0;
				}
				hr::after {
					display: none;
				}
			}
		</style>
	</head>
	<body>
		<slot />
	</body>
</html>
