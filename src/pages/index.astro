---
import LegalLayout from '../layouts/LegalLayout.astro';
---

<LegalLayout title="Formato Legal - Editor de Petições">
	<div class="editor-interface no-print pico">
		<header class="toolbar">
			<nav>
				<ul>
					<li>
						<h1>
							<span aria-hidden="true">⚖️</span> Formato Legal
						</h1>
					</li>
				</ul>
				<ul>
					<li>
						<select id="theme-select" aria-label="Tema"></select>
					</li>
					<li>
						<input
							type="file"
							id="file-upload"
							accept=".md,.txt,.html"
							hidden
						/>
						<button id="upload-btn" class="secondary">Subir Arquivo</button>
					</li>
					<li>
						<button id="download-html-btn" class="secondary">Baixar HTML</button>
					</li>
					<li>
						<button id="clear-btn" class="secondary outline">Limpar</button>
					</li>
					<li>
						<button id="print-btn">Imprimir PDF</button>
					</li>
				</ul>
			</nav>
		</header>

		<nav class="mobile-tabs" role="tablist">
			<button id="tab-editor" type="button" role="tab" aria-selected="true">Editor</button>
			<button id="tab-preview" type="button" role="tab" aria-selected="false" class="outline">
				Visualização
			</button>
		</nav>

		<div class="main-split">
			<section class="editor-pane">
				<header class="pane-header">
					<small><strong>Markdown / Texto</strong></small>
					<select id="template-select" aria-label="Modelo">
						<option value="">Carregar Exemplo...</option>
						<option value="apelacao">Apelação Cível</option>
						<option value="contestacao">Contestação</option>
					</select>
				</header>
				<textarea id="markdown-input" placeholder="Cole seu Markdown aqui..."></textarea>
			</section>

			<section class="preview-pane">
				<header class="pane-header">
					<small><strong>Visualização em A4</strong></small>
					<small id="status-bar"></small>
				</header>
				<div id="legal-preview-container" class="legal-paper">
					<div class="placeholder-msg">
						<p>O resultado da formatação jurídica aparecerá aqui em tempo real.</p>
					</div>
				</div>
			</section>
		</div>
	</div>

	<div class="page-container theme-default">
		<article id="print-article"></article>
	</div>

	<style>
		.editor-interface {
			display: flex;
			flex-direction: column;
			height: 100vh;
			width: 100vw;
			position: fixed;
			top: 0;
			left: 0;
			background: var(--pico-background-color);
			z-index: 1000;
		}

		.editor-interface > header.toolbar {
			padding: 0 1rem;
			background: var(--pico-card-background-color);
			border-bottom: 1px solid var(--pico-muted-border-color);
		}

		.editor-interface > header.toolbar nav {
			padding: 0;
		}

		.editor-interface > header.toolbar h1 {
			font-size: 1.1rem;
			margin: 0;
			padding: 0;
			color: var(--pico-primary);
		}

		.editor-interface > header.toolbar nav ul li {
			padding: 0.5rem 0.25rem;
		}

		.editor-interface > header.toolbar select,
		.editor-interface > header.toolbar button {
			margin: 0;
		}

		.mobile-tabs {
			display: none;
			padding: 0;
			gap: 0;
			border-bottom: 1px solid var(--pico-muted-border-color);
		}

		.mobile-tabs button {
			flex: 1;
			margin: 0;
			border-radius: 0;
		}

		.main-split {
			display: flex;
			flex: 1;
			overflow: hidden;
		}

		.editor-pane {
			width: 40%;
			display: flex;
			flex-direction: column;
			border-right: 1px solid var(--pico-muted-border-color);
			transition: background-color 0.15s;
		}

		.editor-pane.drag-over {
			background: var(--pico-primary-background);
		}

		.preview-pane {
			flex: 1;
			display: flex;
			flex-direction: column;
			background: var(--pico-secondary-background, #e9ecef);
			overflow-y: auto;
		}

		.preview-pane > .legal-paper {
			margin: 2rem auto;
		}

		.pane-header {
			display: flex;
			justify-content: space-between;
			align-items: center;
			padding: 0.5rem 1rem;
			background: var(--pico-card-sectioning-background-color, var(--pico-card-background-color));
			border-bottom: 1px solid var(--pico-muted-border-color);
			margin: 0;
		}

		.pane-header select {
			width: auto;
			min-width: 200px;
			margin: 0;
		}

		#markdown-input {
			flex: 1;
			margin: 0;
			border: none;
			border-radius: 0;
			font-family: 'Fira Code', 'Cascadia Code', monospace;
			font-size: 0.875rem;
			line-height: 1.6;
			resize: none;
		}

		.legal-paper {
			background: white;
			width: 210mm;
			min-height: 297mm;
			padding: 30mm 20mm 25mm 30mm;
			box-shadow: 0 15px 45px rgba(0, 0, 0, 0.15);
			box-sizing: border-box;
		}

		.placeholder-msg {
			height: 100%;
			display: flex;
			align-items: center;
			justify-content: center;
			color: var(--pico-muted-color);
			font-style: italic;
			text-align: center;
		}

		:global(body > .page-container) {
			display: none;
		}

		@media (max-width: 900px) {
			.mobile-tabs {
				display: flex;
			}
			.main-split {
				flex-direction: column;
			}
			.editor-pane {
				width: 100%;
				border-right: none;
				border-bottom: 1px solid var(--pico-muted-border-color);
			}
			.editor-pane.mobile-hidden,
			.preview-pane.mobile-hidden {
				display: none;
			}
			.legal-paper {
				width: 100%;
				min-height: 0;
				padding: 20mm 12mm;
			}
		}

		@media print {
			.no-print {
				display: none !important;
			}
			:global(body > .page-container) {
				display: block !important;
			}
			body {
				background: white !important;
				padding: 0 !important;
			}
		}
	</style>

	<script>
		import '../scripts/editor.ts';
	</script>
</LegalLayout>
